            "tcg-speed-skill"
            "{yugipediaId}.json"
          ]
          select: {
            exist: [
              "yugipedia_id"
            ]
          }
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }

  relations: {
