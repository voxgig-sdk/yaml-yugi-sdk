  "components": {
    "schemas": {
      "Card": {
        "type": "object",
        "description": "Represents a Yu-Gi-Oh! card with comprehensive metadata and text in multiple languages.",
        "properties": {
          "password": {
            "type": "string",
            "description": "8-digit card password/ID",
            "example": "00010000"
          },
          "konamiId": {
            "type": "string",
            "description": "Konami database ID",
            "example": "kdb5000"
          },
          "name": {
            "type": "object",
            "description": "Card name in multiple languages",
            "properties": {
              "en": {
                "type": "string",
                "description": "English name"
              },
              "ja": {
                "type": "string",
                "description": "Japanese name"
              },
              "de": {
                "type": "string",
                "description": "German name"
              },
              "es": {
                "type": "string",
                "description": "Spanish name"
              },
              "fr": {
                "type": "string",
                "description": "French name"
              },
              "it": {
                "type": "string",
                "description": "Italian name"
              },
              "pt": {
                "type": "string",
                "description": "Portuguese name"
              },
              "ko": {
                "type": "string",
                "description": "Korean name"
              },
              "zh": {
                "type": "string",
                "description": "Chinese name"
              }
            }
          },
          "text": {
            "type": "object",
            "description": "Card text in multiple languages",
            "properties": {
              "en": {
                "type": "string",
                "description": "English card text"
              },
              "ja": {
                "type": "string",
                "description": "Japanese card text"
              },
              "de": {
                "type": "string",
                "description": "German card text"
              },
              "es": {
                "type": "string",
                "description": "Spanish card text"
              },
              "fr": {
                "type": "string",
                "description": "French card text"
              },
              "it": {
                "type": "string",
                "description": "Italian card text"
              },
              "pt": {
                "type": "string",
                "description": "Portuguese card text"
              },
              "ko": {
                "type": "string",
                "description": "Korean card text"
              },
              "zh": {
                "type": "string",
                "description": "Chinese card text"
              }
            }
          },
          "cardType": {
            "type": "string",
            "description": "Type of card (Monster, Spell, Trap, etc.)",
            "enum": [
              "Monster",
              "Spell",
              "Trap"
            ]
          },
          "attribute": {
            "type": "string",
            "description": "Card attribute (for monsters)",
            "enum": [
              "DARK",
              "LIGHT",
              "EARTH",
              "WATER",
              "FIRE",
              "WIND",
              "DIVINE"
            ]
          },
          "type": {
            "type": "string",
            "description": "Monster type or spell/trap subtype"
          },
          "level": {
            "type": "integer",
            "description": "Level of the monster card"
          },
          "rank": {
            "type": "integer",
            "description": "Rank of XYZ monster"
          },
          "linkRating": {
            "type": "integer",
            "description": "Link rating for Link monsters"
          },
          "atk": {
            "type": "integer",
            "description": "Attack points",
            "nullable": true
          },
          "def": {
            "type": "integer",
            "description": "Defense points",
            "nullable": true
          },
          "archetype": {
            "type": "array",
            "description": "Archetypes the card belongs to",
            "items": {
              "type": "string"
            }
          },
          "format": {
            "type": "array",
            "description": "Formats where the card is available (OCG, TCG, Master Duel, Rush Duel, Speed Duel)",
            "items": {
              "type": "string",
              "enum": [
                "OCG",
                "TCG",
                "Master Duel",
                "Rush Duel",
                "Speed Duel"
              ]
            }
          }
        }
      },
      "SkillCard": {
        "type": "object",
        "description": "Represents a TCG Speed Duel Skill Card.",
        "properties": {
          "yugipediaId": {
            "type": "string",
            "description": "Yugipedia page ID",
            "example": "yugipedia585581"
          },
          "name": {
            "type": "object",
            "description": "Skill card name in multiple languages",
            "properties": {
              "en": {
                "type": "string",
                "description": "English name"
              }
            }
          },
          "text": {
            "type": "object",
            "description": "Skill card text in multiple languages",
            "properties": {
              "en": {
                "type": "string",
                "description": "English skill text"
              }
            }
          },
          "character": {
            "type": "string",
            "description": "Character associated with the skill"
          },
          "cardType": {
            "type": "string",
            "description": "Type identifier for skill cards",
            "enum": [
              "Skill"
            ]
          }
        }
      },
      "Series": {
        "type": "object",
        "description": "Represents a card series or archetype.",
        "properties": {
          "name": {
            "type": "object",
            "description": "Series/archetype name in multiple languages",
            "properties": {
              "en": {
                "type": "string",
                "description": "English name"
              },
              "ja": {
                "type": "string",
                "description": "Japanese name"
              },
              "de": {
                "type": "string",
                "description": "German name"
              },
              "es": {
                "type": "string",
                "description": "Spanish name"
              },
              "fr": {
                "type": "string",
                "description": "French name"
              },
              "it": {
                "type": "string",
                "description": "Italian name"
              },
              "pt": {
                "type": "string",
                "description": "Portuguese name"
              },
              "ko": {
                "type": "string",
                "description": "Korean name"
              },
              "zh": {
                "type": "string",
                "description": "Chinese name"
              }
            }
          },
          "cards": {
            "type": "array",
            "description": "List of card IDs belonging to this series/archetype",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
