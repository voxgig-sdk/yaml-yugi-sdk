    "/data/cards/{cardId}.json": {
      "get": {
        "summary": "Get OCG/TCG card by password or Konami ID",
        "description": "Returns a single OCG/TCG card by its password (8-digit number) or Konami database ID (e.g., 'kdb5000') in JSON format.",
        "operationId": "getOcgTcgCardById",
        "tags": [
          "Individual Cards"
        ],
        "parameters": [
          {
            "name": "cardId",
            "in": "path",
            "description": "Card password (e.g., '00010000') or Konami ID (e.g., 'kdb5000') or Yugipedia page ID (e.g., 'yugipedia123456')",
            "required": true,
            "schema": {
              "type": "string",
              "pattern": "^(\\d{8}|kdb\\d+|yugipedia\\d+)$"
            },
            "example": "00010000"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response containing the card data",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Card"
                }
              }
            }
          },
          "404": {
            "description": "Card not found"
          }
        }
      }
    },
